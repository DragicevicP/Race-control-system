package rules;

import java.time.LocalDateTime;

import com.ftn.sbnz.model.models.*;
import com.ftn.sbnz.model.enums.*;

rule "Unsafe release creates driver violation"
salience 100
when
    $report : DriverBehaviorReport(
        processed == false,
        unsafeRelease == true,
        $driver : driver
    )
then
    Violation violation = new Violation(
        "UNSAFE_RELEASE",
        "Unsafe release",
        "Driver was released unsafely from the pit lane.",
        ViolationSeverity.MEDIUM,
        null
    );
    DriverViolation driverViolation = new DriverViolation(null, $driver, violation, ViolationSeverity.MEDIUM, false, null, LocalDateTime.now());
    $driver.getViolations().add(driverViolation);
    insert(driverViolation);
    modify($report) { setProcessed(true) }
end

