    modify($report) { setProcessed(true) }
end

rule "Repeated driver violation is marked repeated"
salience 10
when
    $current : DriverViolation(
        repeated == false,
        driver != null,
        violation != null,
        $driver : driver,
        $code : violation.code
    )
    DriverViolation(
        this != $current,
        driver == $driver,
        violation.code == $code
    )
then
    modify($current) {
        setRepeated(true)
    }
end
