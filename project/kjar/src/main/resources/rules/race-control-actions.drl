package rules;

import com.ftn.sbnz.model.models.*;
import com.ftn.sbnz.model.enums.*;

rule "Very bad weather activates red flag"
salience 100
when
    $incident : Incident(
        type == IncidentType.WEATHER,
        dangerLevel == DangerLevel.HIGH,
        resolved == false
    )
    $decision : RaceControlDecision(recommendedFlag == null)
then
    $decision.getReasons().add("Very bad weather conditions detected.");
    modify($decision) {
        setRecommendedFlag(FlagType.RED),
        setSafetyCarStatus(SafetyCarStatus.NONE),
        setExplanation("Very bad weather conditions. Red flag is recommended.")
    }
end

rule "Fully blocked track activates red flag"
salience 100
when
    $incident : Incident(dangerLevel == DangerLevel.HIGH, resolved == false, $sector : sector)
    TrackSector(this == $sector, blocked == true)
    $decision : RaceControlDecision(recommendedFlag == null)
then
    $decision.getReasons().add("Track is fully blocked in the affected sector.");
    modify($decision) {
        setRecommendedFlag(FlagType.RED),
        setSafetyCarStatus(SafetyCarStatus.NONE),
        setExplanation("High danger and fully blocked track. Red flag is recommended.")
    }
end

rule "Active Safety Car with fully blocked track escalates to red flag"
salience 95
when
    RaceStatus(
        currentDecision != null,
        currentDecision.safetyCarStatus == SafetyCarStatus.SAFETY_CAR
    )
    $incident : Incident(dangerLevel == DangerLevel.HIGH, resolved == false, $sector : sector)
    TrackSector(this == $sector, blocked == true)
    $decision : RaceControlDecision(recommendedFlag == null)
then
    $decision.getReasons().add("Safety Car is not enough because the track is fully blocked.");
    modify($decision) {
        setRecommendedFlag(FlagType.RED),
        setSafetyCarStatus(SafetyCarStatus.NONE),
        setExplanation("Safety Car active and track fully blocked. Red flag is recommended.")
    }
end

rule "High danger with medical team on track activates Safety Car"
salience 80
when
    $incident : Incident(
        dangerLevel == DangerLevel.HIGH,
        type != IncidentType.WEATHER,
        resolved == false,
        $sector : sector
    )
    TrackSector(this == $sector, blocked == false, medicalTeamOnTrack == true)
    $decision : RaceControlDecision(
        recommendedFlag == null,
        safetyCarStatus == null
    )
then
    $decision.getReasons().add("Medical team is on track in a high danger situation.");
    modify($decision) {
        setRecommendedFlag(FlagType.DOUBLE_YELLOW),
        setSafetyCarStatus(SafetyCarStatus.SAFETY_CAR),
        setExplanation("High danger and medical team on track. Safety Car is recommended.")
    }
end

