rule "High danger with clear track activates VSC"
salience 55
when
    $incident : Incident(
        dangerLevel == DangerLevel.HIGH,
        type != IncidentType.WEATHER,
        resolved == false,
        multipleSectors == false,
        $sector : sector
    )
    TrackSector(
        this == $sector,
        blocked == false,
        partiallyBlocked == false,
        marshalsOnTrack == false,
        medicalTeamOnTrack == false
    )
    $decision : RaceControlDecision(
        recommendedFlag == null,
        safetyCarStatus == null
    )
then
    $decision.getReasons().add("High danger detected, but track is not blocked and no personnel are on track.");
    modify($decision) {
        setRecommendedFlag(FlagType.DOUBLE_YELLOW),
        setSafetyCarStatus(SafetyCarStatus.VSC),
        setExplanation("High danger with clear track. VSC is recommended.")
    }
end

rule "Double yellow escalates to VSC when danger becomes high"
salience 50
when
    $incident : Incident(
        dangerLevel == DangerLevel.HIGH,
        type != IncidentType.WEATHER,
        resolved == false,
        $sector : sector
    )
    TrackSector(this == $sector, activeFlag == FlagType.DOUBLE_YELLOW, blocked == false)
    $decision : RaceControlDecision(
        recommendedFlag == null,
        safetyCarStatus == null
    )
then
    $decision.getReasons().add("Danger increased while double yellow was active.");
    modify($decision) {
        setRecommendedFlag(FlagType.DOUBLE_YELLOW),
        setSafetyCarStatus(SafetyCarStatus.VSC),
        setExplanation("Double yellow is active and danger became high. VSC is recommended.")
    }
end

rule "Active VSC escalates to Safety Car when danger remains high"
salience 45
when
    RaceStatus(
        currentDecision != null,
        currentDecision.safetyCarStatus == SafetyCarStatus.VSC
    )
    $incident : Incident(
        dangerLevel == DangerLevel.HIGH,
        type != IncidentType.WEATHER,
        resolved == false,
        $sector : sector
    )
    TrackSector(this == $sector, blocked == false)
    $decision : RaceControlDecision(
        recommendedFlag == null,
        safetyCarStatus == null
    )
then
    $decision.getReasons().add("High danger remains while VSC is active.");
    modify($decision) {
        setRecommendedFlag(FlagType.DOUBLE_YELLOW),
        setSafetyCarStatus(SafetyCarStatus.SAFETY_CAR),
        setExplanation("VSC active and danger remains high. Safety Car is recommended.")
    }
end

