rule "High danger with partially blocked track activates Safety Car"
salience 65
when
    $incident : Incident(
        dangerLevel == DangerLevel.HIGH,
        type != IncidentType.WEATHER,
        resolved == false,
        $sector : sector
    )
    TrackSector(this == $sector, blocked == false, partiallyBlocked == true)
    $decision : RaceControlDecision(
