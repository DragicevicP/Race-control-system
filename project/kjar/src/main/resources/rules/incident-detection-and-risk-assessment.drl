package rules;

import com.ftn.sbnz.model.models.*;
import com.ftn.sbnz.model.enums.*;

rule "Crash means high danger"
salience 100
when
    $incident : Incident(
        type == IncidentType.CRASH,
        dangerLevel == null
    )
then
    modify($incident) {
        setDangerLevel(DangerLevel.HIGH)
    }
end

rule "Incident across multiple sectors means high danger"
salience 95
when
    $incident : Incident(
        multipleSectors == true,
        dangerLevel == null
    )
then
    modify($incident) {
        setDangerLevel(DangerLevel.HIGH)
    }
end

rule "Driver left car means high danger"
salience 90
