package rules;

import java.time.Duration;

import com.ftn.sbnz.model.models.*;
import com.ftn.sbnz.model.enums.*;

rule "Blue flag respected before timeout"
salience 60
when
    $monitoring : BlueFlagMonitoring(
        active == true,
        passedFasterCar == true
    )
then
    modify($monitoring) {
        setWarningCount(0),
        setActive(false)
    }
end

rule "Blue flag timeout creates first warning"
salience 50
when
    RaceStatus($now : simulationTime != null)
    $monitoring : BlueFlagMonitoring(
        active == true,
        passedFasterCar == false,
        blueFlagShownAt != null,
        warningCount == 0,
        $shownAt : blueFlagShownAt,
        $driver : driver
    )
    eval(Duration.between($shownAt, $now).getSeconds() >= 20)
then
    modify($monitoring) {
        setWarningCount(1),
        setBlueFlagShownAt($now)
    }
end

rule "Blue flag timeout creates second warning"
salience 50
when
    RaceStatus($now : simulationTime != null)
    $monitoring : BlueFlagMonitoring(
        active == true,
        passedFasterCar == false,
        blueFlagShownAt != null,
        warningCount == 1,
        $shownAt : blueFlagShownAt,
        $driver : driver
    )
    eval(Duration.between($shownAt, $now).getSeconds() >= 20)
then
    modify($monitoring) {
        setWarningCount(2),
        setBlueFlagShownAt($now)
    }
end

rule "Blue flag third timeout creates violation"
salience 50
when
    RaceStatus($now : simulationTime != null)
    $monitoring : BlueFlagMonitoring(
        active == true,
        passedFasterCar == false,
        blueFlagShownAt != null,
        warningCount >= 2,
        $shownAt : blueFlagShownAt,
        $driver : driver
    )
    eval(Duration.between($shownAt, $now).getSeconds() >= 20)
then
    Violation violation = new Violation(
        "IGNORING_BLUE_FLAG",
        "Ignoring blue flag",
        "Driver failed to allow the faster car to pass after two blue flag warnings.",
        ViolationSeverity.MEDIUM,
        null
    );

    DriverViolation driverViolation = new DriverViolation(
        null,
        $driver,
        violation,
        ViolationSeverity.MEDIUM,
        true,
        null,
        $now
    );

    $driver.getViolations().add(driverViolation);
    insert(driverViolation);

    modify($monitoring) {
        setWarningCount(0),
        setActive(false)
    }
end
