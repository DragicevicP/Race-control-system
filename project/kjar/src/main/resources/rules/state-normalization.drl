salience 30
when
    RaceStatus(
        trackStatus == TrackStatus.SAFE,
        currentDecision != null,
        currentDecision.recommendedFlag == FlagType.YELLOW,
        currentDecision.safetyCarStatus == SafetyCarStatus.NONE
    )
    $decision : RaceControlDecision(
        recommendedFlag == null,
        safetyCarStatus == null
    )
then
    $decision.getReasons().add("Track is safe after yellow flag.");
    modify($decision) {
        setRecommendedFlag(FlagType.GREEN),
        setSafetyCarStatus(SafetyCarStatus.NONE),
        setRestartStatus(RestartStatus.NONE),
        setExplanation("Track is safe after yellow flag. Green flag is recommended.")
    }
end

rule "Safe track after double yellow flag recommends green flag"
salience 30
when
    RaceStatus(
        trackStatus == TrackStatus.SAFE,
        currentDecision != null,
        currentDecision.recommendedFlag == FlagType.DOUBLE_YELLOW,
        currentDecision.safetyCarStatus == SafetyCarStatus.NONE
    )
    $decision : RaceControlDecision(
        recommendedFlag == null,
        safetyCarStatus == null
    )
then
    $decision.getReasons().add("Track is safe after double yellow flag.");
    modify($decision) {
        setRecommendedFlag(FlagType.GREEN),
        setSafetyCarStatus(SafetyCarStatus.NONE),
        setRestartStatus(RestartStatus.NONE),
        setExplanation("Track is safe after double yellow flag. Green flag is recommended.")
    }
end

rule "Safe track with no current decision recommends green flag"
salience 25
when
    RaceStatus(
        trackStatus == TrackStatus.SAFE,
        currentDecision == null
    )
    $decision : RaceControlDecision(
        recommendedFlag == null,
        safetyCarStatus == null
    )
then
    $decision.getReasons().add("Track is safe and there is no active race control decision.");
    modify($decision) {
        setRecommendedFlag(FlagType.GREEN),
        setSafetyCarStatus(SafetyCarStatus.NONE),
        setRestartStatus(RestartStatus.NONE),
        setExplanation("Track is safe. Green flag is recommended.")
    }
end
